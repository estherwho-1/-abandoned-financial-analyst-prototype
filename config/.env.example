# OpenAI (for GPT-4o - structured extraction)
OPENAI_API_KEY=sk-...

# Anthropic (for Claude Sonnet - orchestration)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (for Gemini 2.5 Pro - long-context analysis)
GOOGLE_API_KEY=...

# OpenRouter (alternative to individual provider keys — OpenAI-compatible)
# One key can route to any model: https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-...

# Hyperbrowser (web search + fetch)
HYPERBROWSER_API_KEY=...

# E2B (code sandbox)
E2B_API_KEY=...

# Turbopuffer (vector storage)
TURBOPUFFER_API_KEY=...

# Braintrust (observability - optional)
BRAINTRUST_API_KEY=...

# Mode: "mock" or "production" (legacy global toggle)
SAGE_MODE=mock

# Per-service mock flags (all default to true = mocked)
# Set individual flags to "false" to enable that service while keeping others mocked.
# If a flag is "false" but required API keys are missing, it auto-reverts to mock.
MOCK_LLM=true          # Controls Claude, GPT-4o, Gemini
MOCK_SEARCH=true        # Controls Hyperbrowser search + fetch
MOCK_E2B=true           # Controls E2B sandbox
MOCK_MEMORY=true        # Controls Turbopuffer

# Per-role provider routing: "anthropic", "openai", "google", or "openrouter"
# Mix and match — e.g., use native Anthropic for orchestrator but OpenRouter for the rest.
# ORCHESTRATOR_PROVIDER=anthropic
# EXTRACTOR_PROVIDER=openai
# LONGFORM_PROVIDER=google

# Model IDs (OpenRouter format with provider prefix; native providers auto-strip prefix)
# ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4
# EXTRACTOR_MODEL=openai/gpt-4o
# LONGFORM_MODEL=google/gemini-2.5-pro
